# Environment variables for Stroke Workup App — Backend

# REQUIRED
# Generate with: openssl rand -hex 32
JWT_SECRET=your-256-bit-secret-here

# REQUIRED — MongoDB connection string
# Local: mongodb://localhost:27017/stroke
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/stroke
MONGODB_URI=mongodb://strokeadmin:change-me@localhost:27017/stroke?authSource=admin

# RECOMMENDED
# Comma-separated allowed origins (no spaces)
# Example: https://app.yourdomain.com,https://yourdomain.com
ALLOWED_ORIGINS=

# OPTIONAL
JWT_EXPIRY=8h
PORT=5000

# Rate limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─────────────────────────────────────────
# QUICK SETUP — Local Development
# ─────────────────────────────────────────
# 1. Copy this file to .env
# 2. Set JWT_SECRET (generate with: openssl rand -hex 32)
# 3. Set MONGODB_URI (use local MongoDB or Atlas)
# 4. Run: docker-compose up -d
